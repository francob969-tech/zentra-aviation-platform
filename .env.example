# ── Públicas (se exponen al navegador) ──────────────────────────────
# Dominio final del sitio (sin barra final)
NEXT_PUBLIC_SITE_URL=https://aeroejecutivosf.com
# WhatsApp del operador — formato internacional SIN "+" (ej: 5491155555555)
NEXT_PUBLIC_WA_NUMBER=5491100000000
# Email de contacto visible en el sitio
NEXT_PUBLIC_CONTACT_EMAIL=vuelos@aeroejecutivosf.com
# Dominio configurado en Plausible Analytics (vacío = analytics desactivado)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ── Privadas (solo servidor, para /api/quote) ───────────────────────
# API key de Resend (https://resend.com) — vacío = no se envía email
RESEND_API_KEY=
# Remitente verificado en Resend
QUOTE_FROM_EMAIL=cotizaciones@aeroejecutivosf.com
# Casilla del operador que recibe las solicitudes
QUOTE_TO_EMAIL=
# Webhook de n8n para registrar el lead (Sheets, CRM…) — vacío = desactivado
N8N_WEBHOOK_URL=

# ── Panel de administración (/admin) ────────────────────────────────
# Contraseña de acceso al panel — OBLIGATORIA para que el panel funcione
ADMIN_PASSWORD=
# Secreto para firmar la cookie de sesión (cualquier string largo y aleatorio)
ADMIN_SESSION_SECRET=

# ── Almacén de leads ────────────────────────────────────────────────
# Sin estas dos, los leads se guardan en .data/leads.json (solo local/boceto).
# En producción (Vercel/Netlify) son OBLIGATORIAS: crear proyecto en Supabase
# y la tabla `leads` (SQL en PENDIENTES-CLIENTE.md).
SUPABASE_URL=
# Service role key (Settings → API) — solo servidor, nunca NEXT_PUBLIC
SUPABASE_SERVICE_KEY=
